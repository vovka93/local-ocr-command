{
  "id": "local-ocr-command",
  "name": "Local OCR Command",
  "description": "Adds /ocr as a local no-LLM OCR fast-path for inbound images.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "inboundDir": {
        "type": "string",
        "default": "~/.openclaw/media/inbound"
      },
      "dockerImage": {
        "type": "string",
        "default": "tesseractshadow/tesseract4re:latest"
      },
      "defaultLang": {
        "type": "string",
        "default": "eng+ukr"
      },
      "maxAgeMinutes": {
        "type": "integer",
        "minimum": 1,
        "maximum": 1440,
        "default": 10
      }
    }
  }
}
